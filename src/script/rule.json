    "output_parms" : [
        {
            "parm_desc" : "CHECKSUM", 
            "parm_name" : "CHECKSUM"
        }, 
        {
            "parm_desc" : "Rows Scanned", 
            "parm_name" : "ROWS"
        }, 
        {
            "parm_desc" : "Execution Count", 
            "parm_name" : "ts_cnt"
        }, 
        {
            "parm_desc" : "Average Execution Time", 
            "parm_name" : "query_time_avg"
        }, 
        {
            "parm_desc" : "Average Returned Rows", 
            "parm_name" : "rows_sent_avg"
        }, 
        {
            "parm_desc" : "Scan Hit Ratio", 
            "parm_name" : "index_ratio"
        }
    ], 
    "rule_complexity" : "simple", 
    "rule_cmd" : "db.planitem.find({\"schemas\":\"@schema_name@\",\"access_type\" : \"ALL\",\"$or\": [{\"rows\" : {\"$gt\":1}}, {\"rows_examined_per_scan\": {\"$gt\":1}}],\"citem_type\":{\"$ne\":\"materialized_from_subquery\"}}).forEach(function(x){db.sqlinfo.find({checksum:x.checksum}).forEach(function(y){if(x.rows){rows=x.rows}else{rows=x.rows_examined_per_scan}db.@tmp@.save({\"checksum\" :y.checksum,\"ts_cnt\" :y.ts_cnt,\"query_time_avg\" :y.query_time_avg,\"rows_sent_avg\" :y.rows_sent_avg,\"index_ratio\" :y.index_ratio,\"rows\":rows})})})", 
    "rule_desc" : "Full Table Scan", 
    "rule_name" : "TABLE_FULL_SCAN", 
    "rule_status" : "ON", 
    "rule_summary" : "Large-table full table scan: row count exceeds the threshold and scans unnecessary data; use indexes to avoid this.", 
    "rule_type" : "SQLPLAN", 
    "solution" : [
        "1.Evaluate and create missing indexes", 
        "2.Evaluate index creation for MAX/MIN queries", 
        "3.Rebuild invalid indexes; maintain indexes when maintaining partitioned tables", 
        "4.For condition columns using functions or expressions: a.put functions/expressions on the right side of '='; b.create function-based indexes (last resort)", 
        "5.If implicit conversion occurs: a.explicitly cast different predicate types first; b.choose correct data types based on stored data", 
        "6.When using inequality operators <> or != in predicates: a.use them sparingly; b.if values are continuous, replace negation with two ranges; c.if values are limited, use IN list to enumerate alternatives", 
        "7.For fuzzy matches like %a% or %a, prefer precise matching when possible", 
        "8.Rewrite SQL logic (for example MAX value logic) using window functions", 
        "9.For low-selectivity SQL with large result sets: a.add more predicates (for example time filters); b.redesign with partitioned tables; c.use covering indexes", 
        "10.If statistics are inaccurate, trigger statistics collection after bulk data loads"
    ], 
    "weight" : 0.1
}
